    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "keyword.operator",
                    "source.python",
                    "constant.numeric",
                    "source.cobol",
                ],
                "settings": {
                    "foreground": "#DDDDDD",
                },
            },

            {
                "scope": [
                    "entity.name.function.preprocessor",
                    "entity.name.namespace",
                    "entity.name.type",
                ],
                "settings": {
                    "foreground": "#ff0000",
                    "fontStyle": "bold",
                },
            },

            {
                "scope": [
                    "constant.character",
                    "support.variable",
                ],
                "settings": {
                    "foreground": "#ff0000",
                    "fontStyle": "italic",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#ff0000",
                    "fontStyle": "bold italic",
                },
            },

            {
                "scope": [
                    "source.json",
                    "source.json.comments",
                    "variable",
                    "variable.language",
                    "source.cobol",
                ],
                "settings": {
                    "foreground": "#00ff00",
                },
            },

            {
                "scope": [
                    "support.function",
                    "constant.language",
                    "storage.modifier",
                    "meta.preprocessor",
                    "entity.name.scope-resolution",
                    "variable.other.constant",
                    "keyword.operator.comparison.python",
                    "punctuation.definition.list.begin.markdown",
                ],
                "settings": {
                    "foreground": "#00ff00",
                    "fontStyle": "bold",
                },
            },

            {
                "scope": [
                    "support.type",
                    "variable.language.special.self.python",
                ],
                "settings": {
                    "foreground": "#00ff00",
                    "fontStyle": "italic",
                },
            },

            {
                "scope": [
                    "entity.name.function",
                ],
                "settings": {
                    "foreground": "#00ff00",
                    "fontStyle": "bold italic",
                },
            },

            {
                "scope": [
                    "comment",
                ],
                "settings": {
                    "foreground": "#004400",
                    "fontStyle": "bold italic",
                },
            },

            {
                "scope": [
                    "support.type.property-name",
                    "keyword",
                    "keyword.other.using",
                    "keyword.operator.logical.python",
                ],
                "settings": {
                    "foreground": "#7000FF",
                },
            },

            {
                "scope": [
                    "keyword.control",
                    "storage.type",
                ],
                "settings": {
                    "foreground": "#7000FF",
                    "fontStyle": "bold",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#7000FF",
                    "fontStyle": "italic",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#7000FF",
                    "fontStyle": "bold italic",
                },
            },

            {
                "scope": [
                    "markup.heading",
                ],
                "settings": {
                    "foreground": "#888888",
                },
            },

            {
                "scope": [
                    "string",
                    "string.regexp"
                ],
                "settings": {
                    "foreground": "#ff8800",
                },
            },
            
            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#ff8800",
                    "fontStyle": "italic",
                },
            },
            {
                "scope": [
                    "markup.bold",
                ],
                "settings": {
                    "foreground": "#ffff00",
                    "fontStyle": "bold",
                },
            },

            {
                "scope": [
                    "entity.other.inherited-class"
                ],
                "settings": {
                    "foreground": "#ffff00",
                    "fontStyle": "italic",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#ffff00",
                    "fontStyle": "bold italic",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#ff4800",
                },
            },

            {
                "scope": [
                ],
                "settings": {
                    "foreground": "#ff4800",
                    "fontStyle": "bold",

                },
            },

            {
                "scope": [
                    "invalid",
                ],
                "settings": {
                    "foreground": "#ff4800",
                    "fontStyle": "italic",
                },
            },

            {
                "scope": [
                    "constant.character.escape",
                ],
                "settings": {
                    "foreground": "#ff4800",
                    "fontStyle": "bold italic",

                },
            },

        ]
    },
